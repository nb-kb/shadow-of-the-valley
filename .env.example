# Template for local secrets. Copy this file to ".env" and fill in real values.
# The real ".env" is git-ignored and must never be committed.

# Google Gemini (AI Studio) API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Local models (LM Studio) need no key, but aider expects a placeholder:
# OPENAI_API_BASE=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
